# ─── Adaptive Workspace → Notion ─────────────────────────────────────────────
# 1. Crie uma Internal Integration em https://www.notion.so/my-integrations
# 2. Copie o secret para NOTION_TOKEN
# 3. Abra a página "Adaptive Workspace" e compartilhe com a integration (Full access)
# 4. Os IDs abaixo são data_source_id das collections (Notion API v5)

NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=39d5615ab27481b2892cff223534f8ba
NOTION_PROGRESS_DB_ID=b1259739-108d-4b52-9eeb-72295b8dd456
NOTION_ASSESSMENTS_DB_ID=1ddf0448-973c-4f2e-93e7-6277a4929390
NOTION_SESSIONS_DB_ID=20e5c351-ee7f-4747-8471-5bf9c47e2771

# Opcional — legado. O painel Acompanhamento lê o Notion no servidor (sem campo na tela).
ADAPTIVE_OPS_SECRET=

# ─── Área do Cliente → Entregas (GitHub) ─────────────────────────────────────
# PAT fine-grained com acesso read-only (Contents, Pull requests, Deployments)
# aos repositórios dos projetos do cliente. Necessário para repos privados e
# para não esbarrar no rate limit da API pública.
GITHUB_TOKEN=
